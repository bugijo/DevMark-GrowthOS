# DevMark GrowthOS — exemplo para desenvolvimento local
# Copie para .env. Nunca coloque credenciais reais neste arquivo nem faça commit do .env.

# Aplicação
COMPOSE_PROJECT_NAME=devmark-growthos
APP_ENV=development
APP_NAME=DevMark GrowthOS
APP_VERSION=0.1.0-dev
LOG_LEVEL=INFO
TIMEZONE=America/Sao_Paulo
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
API_V1_PREFIX=/api/v1

# Frontend — somente valores públicos podem usar NEXT_PUBLIC_*
NEXT_PUBLIC_APP_NAME=DevMark GrowthOS
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
BACKEND_INTERNAL_URL=http://backend:8000

# PostgreSQL local
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=growthos
POSTGRES_USER=growthos_local
POSTGRES_PASSWORD=local-postgres-only-change-before-shared-use
DATABASE_URL=postgresql+psycopg://growthos_local:local-postgres-only-change-before-shared-use@postgres:5432/growthos

# Autenticação — valores abaixo são exclusivamente locais e não servem para produção
AUTH_SECRET_KEY=local-auth-key-change-before-shared-use-at-least-32-characters
TOKEN_SECRET_KEY=local-token-key-change-before-shared-use-at-least-32-characters
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=7
PASSWORD_RESET_TTL_MINUTES=30
SESSION_COOKIE_NAME=growthos_session
CSRF_COOKIE_NAME=growthos_csrf
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
ALLOWED_ORIGINS=http://localhost:3000

# Rate limiting local
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_ORIGIN_MULTIPLIER=20

# Worker baseado na tabela de jobs
JOB_POLL_INTERVAL_SECONDS=2
JOB_BATCH_SIZE=10
JOB_MAX_ATTEMPTS=3
JOB_TIMEOUT_SECONDS=120
JOB_RETRY_BASE_SECONDS=5
JOB_RETRY_MAX_SECONDS=300
WORKER_HEARTBEAT_MAX_AGE_SECONDS=30

# Providers: mock é obrigatório e padrão; nenhuma API paga é necessária
AI_PROVIDER=mock
IMAGE_PROVIDER=mock
MOCK_PROVIDER_SEED=devmark-growthos
MOCK_PROVIDER_LATENCY_MS=0

# Hermes é opcional e permanece desligado no ambiente padrão
HERMES_ENABLED=false
HERMES_BASE_URL=http://host.docker.internal:8080
HERMES_TIMEOUT_SECONDS=30

# Armazenamento S3 compatível / MinIO local
STORAGE_PROVIDER=minio
S3_ENDPOINT_URL=http://minio:9000
S3_PUBLIC_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=growthos-local
S3_ACCESS_KEY_ID=growthos_minio_local
S3_SECRET_ACCESS_KEY=local-minio-only-change-before-shared-use
S3_USE_SSL=false
MINIO_ROOT_USER=growthos_minio_local
MINIO_ROOT_PASSWORD=local-minio-only-change-before-shared-use
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,image/webp
SIGNED_URL_TTL_SECONDS=900

# E-mail local capturado pelo Mailpit; nenhuma mensagem sai para a internet.
EMAIL_PROVIDER=smtp
EMAIL_FROM=no-reply@devmark.local
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
MAILPIT_UI_PORT=8025

# Dados de demonstração exclusivamente fictícios. Produção exige SEED_DEMO_DATA=false.
SEED_DEMO_DATA=true
DEMO_ORGANIZATION_NAME=DevMark Demo
DEMO_ADMIN_EMAIL=admin@devmark.local
DEMO_ADMIN_PASSWORD=local-demo-only-change-before-use
DEMO_CLIENT_EMAIL=client@clinicafeliz.local
DEMO_CLIENT_PASSWORD=local-demo-client-only-change-before-use

# Observabilidade local
STRUCTURED_LOGS=true
CORRELATION_ID_HEADER=X-Request-ID
SENTRY_DSN=

# Produção deve definir APP_ENV=production, SESSION_COOKIE_SECURE=true,
# SEED_DEMO_DATA=false e fornecer, fora do repositório:
# - segredos aleatórios e exclusivos;
# - credenciais do banco e storage;
# - chave de criptografia para credenciais de providers;
# - SMTP ou outro serviço transacional autorizado;
# - providers remotos opcionais, sempre por configuração segura.
